# ABC Local WordPress Stack Env
# Copy to .env if you want custom values, or leave as-is.

DB_HOST=mariadb
DB_PORT=3306
DB_NAME=abcnews
DB_USER=abcnews
DB_PASS=abcnewspass
DB_ROOT_PASS=rootpass
DB_PREFIX=wp_

# PHP-FPM port inside container (only used by healthcheck)
PHP_FPM_PORT=9000

# WordPress Site
WP_DEBUG=true
WP_DEBUG_LOG=true

# External access
HOST_PORT=8085
